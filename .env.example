# PostgreSQL / TimescaleDB
POSTGRES_USER=tek
POSTGRES_PASSWORD=tek_secret
POSTGRES_DB=tek_sensor
POSTGRES_HOST=timescaledb
POSTGRES_PORT=5432

# Backend
DATABASE_URL=postgresql+asyncpg://tek:tek_secret@timescaledb:5432/tek_sensor
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRE_MINUTES=1440
ADMIN_LOGIN=admin
ADMIN_PASSWORD=admin
VIEWER_LOGIN=viewer
VIEWER_PASSWORD=viewer
# LAN-IP хоста с backend — для сниппета ESP при создании датчика (не localhost)
API_PUBLIC_BASE_URL=http://192.168.0.181:8000
